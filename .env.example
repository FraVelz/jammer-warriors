# Required in production builds. Copy to .env.local for local dev.
NEXT_PUBLIC_PAYPAL_EMAIL=cotsalva3@gmail.com
NEXT_PUBLIC_DELIVERY_FEE=5
# Canonical URL — must match your public domain on Vercel (custom domain if used)
NEXT_PUBLIC_SITE_URL=https://jammer-warriors.vercel.app

# Stripe Checkout (optional — card payments enabled when set)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Firebase client (public — from Firebase console / firebase apps:sdkconfig)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=jammer-warriors.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=jammer-warriors
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=620436157169
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=jammer-warriors.firebasestorage.app

# Firebase Admin (server only — service account JSON)
FIREBASE_ADMIN_PROJECT_ID=jammer-warriors
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@jammer-warriors.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
