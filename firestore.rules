rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/admin { allow read, write: if false; }
    match /config/site {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/config/admin).data.uid;
    }
    match /rateLimits/{id} { allow read, write: if false; }
  }
}